# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/

# Virtual envs
.venv/
venv/
env/

# Hologram runtime: ignore the event log, but keep authored checks under
# version control (checks.py is source; events.jsonl is a runtime artifact).
**/.hologram/*
!**/.hologram/checks.py
# examples/minimal doubles as the dashboard-test fixture; its event log is
# hand-crafted test data, not a runtime artifact.
!examples/minimal/.hologram/events.jsonl

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
